# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional: Langfuse tracing (https://cloud.langfuse.com → Settings → API Keys).
# If unset, tracing is disabled and the app runs normally.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
